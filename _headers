# Cloudflare Pages — Custom HTTP headers
# https://developers.cloudflare.com/pages/configuration/headers/
# (Netlify also supports this file format, so it works on both platforms.)

/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: payment=(*)

# Allow analytics.html to be embedded as an iframe within the same site (admin dashboard)
/analytics.html
  X-Frame-Options: SAMEORIGIN

# Allow sizeguide to be embedded as an iframe in the product page size modal
# CF Pages serves sizeguide.html at /sizeguide (pretty URL) — both rules needed
/sizeguide
  X-Frame-Options: SAMEORIGIN

/sizeguide.html
  X-Frame-Options: SAMEORIGIN

/*.html
  Cache-Control: no-cache

/*.css
  Cache-Control: public, max-age=31536000, immutable

/*.js
  Cache-Control: public, max-age=31536000, immutable

/sw.js
  Cache-Control: no-cache, no-store, must-revalidate

/*.woff2
  Cache-Control: public, max-age=3600, must-revalidate

/*.woff
  Cache-Control: public, max-age=3600, must-revalidate

/*.png
  Cache-Control: public, max-age=2592000

/*.jpg
  Cache-Control: public, max-age=2592000

/*.webp
  Cache-Control: public, max-age=2592000

/*.mp4
  Cache-Control: public, max-age=2592000

# Apple Pay domain verification file (required by Stripe / Apple Pay)
/.well-known/apple-developer-merchantid-domain-association
  Content-Type: application/octet-stream
  Cache-Control: no-cache
