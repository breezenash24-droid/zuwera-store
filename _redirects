# Route /api/* to Netlify functions — keeps the URL scheme consistent across
# Netlify, Vercel, and Cloudflare Pages (all platforms serve functions at /api/).
/api/*  /.netlify/functions/:splat  200

# Clean product URLs — e.g. /vogue → product.html?slug=vogue
# Netlify serves static files first, so index.html, admin.html, etc. still work.
# This catch-all only fires for paths that don't match a real file.
/*  /product.html?slug=:splat  200
